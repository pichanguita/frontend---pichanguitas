# ==================================================
# CONFIGURACIÓN FRONTEND - PICHANGUITAS
# ==================================================
# Este archivo sirve como plantilla para configurar
# las variables de entorno del frontend React + Vite.
# Copiar este archivo como .env y configurar valores.
# ==================================================
# NOTA: En Vite, todas las variables deben tener
# el prefijo VITE_ para ser accesibles en el cliente.
# ==================================================

# ==================================================
# API - BACKEND
# ==================================================
# URL base del API backend
#
# EJEMPLOS:
# - Desarrollo local: http://localhost:4009
# - Railway: https://tu-backend.railway.app
#
# Railway: Configurar esta variable con la URL pública
# de tu servicio backend desplegado
VITE_API_BASE_URL=http://localhost:4009

# ==================================================
# APLICACIÓN
# ==================================================
# Versión de la aplicación
VITE_APP_VERSION=2.2

# Versión del almacenamiento local (para cache)
VITE_STORAGE_VERSION=2.2

# Puerto para desarrollo local (solo aplica en dev)
# Railway ignora esta variable y asigna su propio puerto
VITE_PORT=3009

# ==================================================
# SEGURIDAD
# ==================================================
# Tiempo de expiración de sesión (milisegundos)
# 28800000 ms = 8 horas
VITE_SESSION_TIMEOUT=28800000

# Número máximo de intentos de login fallidos
VITE_MAX_LOGIN_ATTEMPTS=3

# ==================================================
# CONTACTO
# ==================================================
# Teléfono de contacto (formato internacional)
VITE_CONTACT_PHONE=+51999999999

# Email de contacto
VITE_CONTACT_EMAIL=contacto@pichanguitas.com

# ==================================================
# CONFIGURACIÓN ADICIONAL (OPCIONAL)
# ==================================================
# Activar modo debug (true/false)
# VITE_DEBUG_MODE=false

# Google Maps API Key (si se implementa)
# VITE_GOOGLE_MAPS_API_KEY=

# Analytics ID (si se implementa)
# VITE_ANALYTICS_ID=
